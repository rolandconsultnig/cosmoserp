# Production public URL (no trailing slash). Used for canonical links, Open Graph, and JSON-LD.
# Set at build time: VITE_SITE_URL=https://cosmoserp.com.ng npm run build
VITE_SITE_URL=https://cosmoserp.com.ng

# API base for the marketplace SPA (if different from same-origin /api)
# VITE_API_URL=https://cosmoserp.com.ng/api

# Dev only: where Vite proxies /api (default http://127.0.0.1:5133). Use if your API runs on another port.
# VITE_API_PROXY_TARGET=http://127.0.0.1:5000

# Set to false to stop sending anonymous page-view beacons to the API (admin visitor dashboard)
# VITE_ENABLE_VISIT_ANALYTICS=false
