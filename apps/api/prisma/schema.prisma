  sender    User   @relation("IntranetMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User   @relation("IntranetMessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([senderId])
  @@index([recipientId])
}

enum KnowledgeArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model KnowledgeCategory {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  slug        String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, name])
  @@unique([tenantId, slug])
  @@index([tenantId, isActive])
}

model KnowledgeArticle {
  id          String                @id @default(uuid())
  tenantId    String
  categoryId  String?
  title       String
  slug        String
  excerpt     String?
  body        String
  status      KnowledgeArticleStatus @default(DRAFT)
  publishedAt DateTime?
  createdById String?
  updatedById String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId, status, publishedAt])
  @@index([tenantId, categoryId])
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

model PayrollRun {
  id           String        @id @default(uuid())
  tenantId     String
  period       String
  month        Int
  year         Int
  status       PayrollStatus @default(DRAFT)
  totalGross   Decimal       @db.Decimal(18, 2)
  totalPaye    Decimal       @db.Decimal(18, 2)
  totalPension Decimal       @db.Decimal(18, 2)
  totalNhf     Decimal       @db.Decimal(18, 2)
  totalItf     Decimal       @db.Decimal(18, 2)
  totalNet     Decimal       @db.Decimal(18, 2)
  nibssFile    String?
  processedAt  DateTime?
  createdById  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  payslips Payslip[]

  @@unique([tenantId, month, year])
  @@index([tenantId])
}

enum PayrollStatus {
  DRAFT
  PROCESSING
  APPROVED
  PAID
  CANCELLED
}

model Payslip {
  id              String   @id @default(uuid())
  payrollRunId    String
  employeeId      String
  grossSalary     Decimal  @db.Decimal(18, 2)
  basicSalary     Decimal  @db.Decimal(18, 2)
  housing         Decimal  @default(0) @db.Decimal(18, 2)
  transport       Decimal  @default(0) @db.Decimal(18, 2)
  otherAllowances Decimal  @default(0) @db.Decimal(18, 2)
  payeeTax        Decimal  @db.Decimal(18, 2)
  employeePension Decimal  @db.Decimal(18, 2)
  employerPension Decimal  @db.Decimal(18, 2)
  nhf             Decimal  @default(0) @db.Decimal(18, 2)
  itf             Decimal  @default(0) @db.Decimal(18, 2)
  otherDeductions Decimal  @default(0) @db.Decimal(18, 2)
  netPay          Decimal  @db.Decimal(18, 2)
