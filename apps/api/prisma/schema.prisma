// Cosmos ERP - Prisma Schema
// Multi-tenant Nigerian ERP Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// SUPER ADMIN / PLATFORM LAYER
// ─────────────────────────────────────────────

model Platform {
  id                 String   @id @default(uuid())
  name               String   @default("Cosmos ERP")
  commissionRate     Decimal  @default(0.05) @db.Decimal(5, 4)
  vatRate            Decimal  @default(0.075) @db.Decimal(5, 4)
  currency           String   @default("NGN")
  featureFlags       Json?
  maintenanceMode    Boolean  @default(false)
  maintenanceMessage String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AdminUser {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  firstName    String
  lastName     String
  role         AdminRole  @default(SUPPORT)
  isActive     Boolean    @default(true)
  lastLoginAt  DateTime?
  mfaEnabled   Boolean    @default(false)
  mfaSecret   String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
  assignedPlatformTickets PlatformSupportTicket[] @relation("AssignedPlatformTickets")
}

enum AdminRole {
  SUPER_ADMIN
  FINANCE_ADMIN
  SUPPORT
  COMPLIANCE
}

// ─────────────────────────────────────────────
// TENANT (Business) LAYER
// ─────────────────────────────────────────────

model Tenant {
  id                  String           @id @default(uuid())
  businessName        String
  tradingName         String?
  tin                 String?          @unique
  rcNumber            String?
  email               String           @unique
  phone               String
  address             String
  city                String
  state               String
  country             String           @default("Nigeria")
  logoUrl             String?
  website             String?
  businessType        BusinessType     @default(SOLE_PROPRIETORSHIP)
  industry            String?
  kycStatus           KYCStatus        @default(PENDING)
  kycDocuments        Json?
  kycFormData         Json?
  kycRejectionReason  String?
  kycVerifiedAt       DateTime?
  kycVerifiedBy       String?
  isActive            Boolean          @default(true)
  isMarketplaceSeller Boolean          @default(false)
  subscriptionPlan    SubscriptionPlan @default(STARTER)
  subscriptionStatus  SubStatus        @default(TRIAL)
  trialEndsAt         DateTime?
  subscriptionEndsAt  DateTime?
  nrsTaxpayerId       String?
  nrsRegisteredAt     DateTime?
  bankName            String?
  bankAccountNumber   String?
  bankAccountName     String?
  bankSortCode        String?
  paystackRecipientCode String?        // cached Paystack transfer recipient code (NGN payouts)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  onboardedByAgentId  String?
  onboardedBy         User?            @relation("OnboardedTenants", fields: [onboardedByAgentId], references: [id])

  users             User[]
  products          Product[]
  customers         Customer[]
  suppliers         Supplier[]
  invoices          Invoice[]
  quotes            Quote[]
  purchaseOrders    PurchaseOrder[]
  warehouses        Warehouse[]
  employees         Employee[]
  payrollRuns       PayrollRun[]
  accounts          Account[]
  journalEntries    JournalEntry[]
  taxFilings        TaxFiling[]
  subscriptions     Subscription[]
  marketplaceOrders MarketplaceOrder[]
  auditLogs         AuditLog[]
  nrsLogs           NRSLog[]
  currencies        TenantCurrency[]
  supportTickets    SupportTicket[]
  callLogs          CallLog[]
  posSales          POSSale[]
  logisticsAgents   LogisticsAgent[]
  deliveries        Delivery[]
  kycDocumentFiles  KycDocument[]
  accountingPeriods AccountingPeriod[]
  marketplaceSellerPayouts MarketplaceSellerPayout[]

  @@index([kycStatus])
  @@index([subscriptionStatus])
  @@index([onboardedByAgentId])
}

enum BusinessType {
  SOLE_PROPRIETORSHIP
  PARTNERSHIP
  LIMITED_LIABILITY
  PUBLIC_LIMITED
  NGO
  GOVERNMENT
}

enum KYCStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum KycDocumentType {
  CAC_CERTIFICATE
  CAC_PARTICULARS
  CAC_FORM
  DIRECTOR_ID
  DIRECTOR_PHOTO
  PROOF_OF_ADDRESS
  UTILITY_BILL
  BANK_STATEMENT
  TAX_CLEARANCE
  OTHER
}

model KycDocument {
  id           String          @id @default(uuid())
  tenantId     String
  documentType KycDocumentType
  filePath     String
  fileName     String
  mimeType     String?
  fileSize     Int?
  notes        String?
  uploadedById String?
  uploadedAt   DateTime        @default(now())

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy User?  @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([documentType])
}

enum SubscriptionPlan {
  STARTER
  GROWTH
  ENTERPRISE
}

enum SubStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  SUSPENDED
}

model Subscription {
  id              String           @id @default(uuid())
  tenantId        String
  plan            SubscriptionPlan
  status          SubStatus
  billingCycle    BillingCycle     @default(MONTHLY)
  amount          Decimal          @db.Decimal(12, 2)
  currency        String           @default("NGN")
  startDate       DateTime
  endDate         DateTime?
  nextBillingDate DateTime?
  paystackSubCode String?
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  tenant   Tenant                @relation(fields: [tenantId], references: [id])
  payments SubscriptionPayment[]

  @@index([tenantId])
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

model SubscriptionPayment {
  id             String        @id @default(uuid())
  subscriptionId String
  amount         Decimal       @db.Decimal(12, 2)
  currency       String        @default("NGN")
  status         PaymentStatus
  reference      String        @unique
  gateway        String
  paidAt         DateTime?
  metadata       Json?
  createdAt      DateTime      @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id])
}

// ─────────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole  @default(STAFF)
  permissions  Json?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  avatarUrl    String?
  phone        String?
  mfaEnabled   Boolean   @default(false)
  mfaSecret   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant               Tenant          @relation(fields: [tenantId], references: [id])
  createdInvoices      Invoice[]       @relation("InvoiceCreator")
  auditLogs            AuditLog[]
  refreshTokens        RefreshToken[]
  assignedTickets      SupportTicket[] @relation("AssignedTickets")
  ticketComments       TicketComment[]
  agentCallLogs        CallLog[]       @relation("AgentCallLogs")
  posCashierSales      POSSale[]       @relation("POSCashier")
  onboardedTenants     Tenant[]        @relation("OnboardedTenants")
  kycDocumentsUploaded KycDocument[]
  closedAccountingPeriods AccountingPeriod[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

enum UserRole {
  OWNER
  ADMIN
  ACCOUNTANT
  SALES
  WAREHOUSE
  HR
  STAFF
  VIEWER
  FIELD_AGENT
  CRM_MANAGER
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// FINANCE — CHART OF ACCOUNTS
// ─────────────────────────────────────────────

model Account {
  id              String      @id @default(uuid())
  tenantId        String
  code            String
  name            String
  type            AccountType
  subType         String?
  description     String?
  currency        String      @default("NGN")
  balance         Decimal     @default(0) @db.Decimal(18, 2)
  isSystemAccount Boolean     @default(false)
  isActive        Boolean     @default(true)
  parentId        String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  parent       Account?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  children     Account[]     @relation("AccountHierarchy")
  journalLines JournalLine[]

  @@unique([tenantId, code])
  @@index([tenantId, type])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model JournalEntry {
  id           String        @id @default(uuid())
  tenantId     String
  reference    String
  description  String
  date         DateTime
  currency     String        @default("NGN")
  exchangeRate Decimal       @default(1) @db.Decimal(18, 6)
  status       JournalStatus @default(DRAFT)
  sourceType   String?
  sourceId     String?
  createdById  String?
  postedAt     DateTime?
  reversesEntryId String?    @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  lines        JournalLine[]
  reversesEntry JournalEntry? @relation("JournalReversals", fields: [reversesEntryId], references: [id])
  reversedBy    JournalEntry[] @relation("JournalReversals")

  @@index([tenantId, date])
  @@index([sourceType, sourceId])
}

enum JournalStatus {
  DRAFT
  POSTED
  REVERSED
}

model JournalLine {
  id             String   @id @default(uuid())
  journalEntryId String
  accountId      String
  description    String?
  debit          Decimal  @default(0) @db.Decimal(18, 2)
  credit         Decimal  @default(0) @db.Decimal(18, 2)
  createdAt      DateTime @default(now())

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])
}

model AccountingPeriod {
  id         String   @id @default(uuid())
  tenantId   String
  name       String
  startDate  DateTime
  endDate    DateTime
  isClosed   Boolean  @default(false)
  closedAt   DateTime?
  closedById String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  closedBy User?  @relation(fields: [closedById], references: [id])

  @@unique([tenantId, startDate])
  @@index([tenantId, startDate])
  @@index([tenantId, isClosed])
}

model TenantCurrency {
  id           String   @id @default(uuid())
  tenantId     String
  code         String
  name         String
  symbol       String
  exchangeRate Decimal  @db.Decimal(18, 6)
  isBase       Boolean  @default(false)
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
}

// ─────────────────────────────────────────────
// CUSTOMERS & SUPPLIERS
// ─────────────────────────────────────────────

model Customer {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  email       String?
  phone       String?
  whatsapp    String?
  address     String?
  city        String?
  state       String?
  country     String   @default("Nigeria")
  tin         String?
  rcNumber    String?
  creditLimit Decimal  @default(0) @db.Decimal(18, 2)
  creditUsed  Decimal  @default(0) @db.Decimal(18, 2)
  currency    String   @default("NGN")
  isActive    Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  invoices       Invoice[]
  quotes         Quote[]
  supportTickets SupportTicket[]
  callLogs       CallLog[]
  posSales       POSSale[]

  @@index([tenantId])
}

model Supplier {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  email        String?
  phone        String?
  address      String?
  city         String?
  state        String?
  country      String   @default("Nigeria")
  tin          String?
  currency     String   @default("NGN")
  paymentTerms Int      @default(30)
  isActive     Boolean  @default(true)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  purchaseOrders PurchaseOrder[]

  @@index([tenantId])
}

// ─────────────────────────────────────────────
// INVENTORY & PRODUCTS
// ─────────────────────────────────────────────

model Warehouse {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  code      String
  address   String?
  city      String?
  state     String?
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  stockLevels StockLevel[]
  stockMoves  StockMovement[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model ProductCategory {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  parentId    String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  parent   ProductCategory?     @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ProductCategory[]    @relation("CategoryHierarchy")
  products Product[]
  listings MarketplaceListing[]
}

model Product {
  id              String   @id @default(uuid())
  tenantId        String
  categoryId      String?
  sku             String
  barcode         String?
  name            String
  description     String?
  unit            String   @default("piece")
  costPrice       Decimal  @db.Decimal(18, 2)
  sellingPrice    Decimal  @db.Decimal(18, 2)
  currency        String   @default("NGN")
  vatRate         Decimal  @default(0.075) @db.Decimal(5, 4)
  whtRate         Decimal  @default(0) @db.Decimal(5, 4)
  reorderPoint    Int      @default(10)
  reorderQty      Int      @default(50)
  weight          Decimal? @db.Decimal(10, 3)
  dimensions      Json?
  images          String[]
  isActive        Boolean  @default(true)
  isMarketplace   Boolean  @default(false)
  marketplaceDesc String?
  landedCost      Decimal  @default(0) @db.Decimal(18, 2)
  hscode          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  category            ProductCategory?     @relation(fields: [categoryId], references: [id])
  stockLevels         StockLevel[]
  stockMoves          StockMovement[]
  invoiceLines        InvoiceLine[]
  quoteLInes          QuoteLine[]
  poLines             PurchaseOrderLine[]
  landedCosts         LandedCost[]
  marketplaceListings MarketplaceListing[]
  posSaleLines        POSSaleLine[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([isMarketplace])
}

model StockLevel {
  id          String   @id @default(uuid())
  tenantId    String
  productId   String
  warehouseId String
  quantity    Int      @default(0)
  reservedQty Int      @default(0)
  updatedAt   DateTime @updatedAt

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@index([tenantId])
}

model StockMovement {
  id          String        @id @default(uuid())
  tenantId    String
  productId   String
  warehouseId String
  type        StockMoveType
  quantity    Int
  reference   String?
  sourceId    String?
  sourceType  String?
  notes       String?
  createdById String?
  createdAt   DateTime      @default(now())

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@index([tenantId, productId])
  @@index([sourceType, sourceId])
}

enum StockMoveType {
  PURCHASE_RECEIPT
  SALE_DELIVERY
  TRANSFER
  ADJUSTMENT
  RETURN
  DAMAGE
  OPENING_STOCK
}

model LandedCost {
  id          String   @id @default(uuid())
  tenantId    String
  productId   String
  poId        String?
  description String
  amount      Decimal  @db.Decimal(18, 2)
  currency    String   @default("NGN")
  costType    String
  date        DateTime
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
}

// ─────────────────────────────────────────────
// PURCHASE ORDERS
// ─────────────────────────────────────────────

model PurchaseOrder {
  id              String    @id @default(uuid())
  tenantId        String
  supplierId      String
  poNumber        String
  status          POStatus  @default(DRAFT)
  issueDate       DateTime  @default(now())
  expectedDate    DateTime?
  currency        String    @default("NGN")
  exchangeRate    Decimal   @default(1) @db.Decimal(18, 6)
  subtotal        Decimal   @db.Decimal(18, 2)
  vatAmount       Decimal   @default(0) @db.Decimal(18, 2)
  whtAmount       Decimal   @default(0) @db.Decimal(18, 2)
  totalAmount     Decimal   @db.Decimal(18, 2)
  notes           String?
  isAutoGenerated Boolean   @default(false)
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant   Tenant              @relation(fields: [tenantId], references: [id])
  supplier Supplier            @relation(fields: [supplierId], references: [id])
  lines    PurchaseOrderLine[]

  @@unique([tenantId, poNumber])
  @@index([tenantId])
}

enum POStatus {
  DRAFT
  SENT
  PARTIAL
  RECEIVED
  CANCELLED
}

model PurchaseOrderLine {
  id          String  @id @default(uuid())
  poId        String
  productId   String
  description String?
  quantity    Int
  unitPrice   Decimal @db.Decimal(18, 2)
  vatRate     Decimal @default(0.075) @db.Decimal(5, 4)
  vatAmount   Decimal @db.Decimal(18, 2)
  lineTotal   Decimal @db.Decimal(18, 2)
  receivedQty Int     @default(0)

  po      PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id])
}

// ─────────────────────────────────────────────
// SALES — QUOTES & INVOICES (NRS E-INVOICING)
// ─────────────────────────────────────────────

model Quote {
  id             String      @id @default(uuid())
  tenantId       String
  customerId     String
  quoteNumber    String
  status         QuoteStatus @default(DRAFT)
  issueDate      DateTime    @default(now())
  expiryDate     DateTime?
  currency       String      @default("NGN")
  exchangeRate   Decimal     @default(1) @db.Decimal(18, 6)
  subtotal       Decimal     @db.Decimal(18, 2)
  vatAmount      Decimal     @default(0) @db.Decimal(18, 2)
  discountAmount Decimal     @default(0) @db.Decimal(18, 2)
  totalAmount    Decimal     @db.Decimal(18, 2)
  notes          String?
  terms          String?
  createdById    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id])
  customer Customer    @relation(fields: [customerId], references: [id])
  lines    QuoteLine[]
  invoice  Invoice?

  @@unique([tenantId, quoteNumber])
  @@index([tenantId])
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

model QuoteLine {
  id          String  @id @default(uuid())
  quoteId     String
  productId   String?
  description String
  quantity    Decimal @db.Decimal(18, 3)
  unitPrice   Decimal @db.Decimal(18, 2)
  vatRate     Decimal @default(0.075) @db.Decimal(5, 4)
  vatAmount   Decimal @db.Decimal(18, 2)
  whtRate     Decimal @default(0) @db.Decimal(5, 4)
  whtAmount   Decimal @default(0) @db.Decimal(18, 2)
  lineTotal   Decimal @db.Decimal(18, 2)

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
}

model Invoice {
  id                String        @id @default(uuid())
  tenantId          String
  customerId        String
  quoteId           String?       @unique
  invoiceNumber     String
  invoiceType       InvoiceType   @default(B2B)
  status            InvoiceStatus @default(DRAFT)
  issueDate         DateTime      @default(now())
  dueDate           DateTime
  currency          String        @default("NGN")
  exchangeRate      Decimal       @default(1) @db.Decimal(18, 6)
  subtotal          Decimal       @db.Decimal(18, 2)
  vatAmount         Decimal       @default(0) @db.Decimal(18, 2)
  whtAmount         Decimal       @default(0) @db.Decimal(18, 2)
  discountAmount    Decimal       @default(0) @db.Decimal(18, 2)
  totalAmount       Decimal       @db.Decimal(18, 2)
  amountPaid        Decimal       @default(0) @db.Decimal(18, 2)
  amountDue         Decimal       @db.Decimal(18, 2)
  notes             String?
  terms             String?
  // NRS E-Invoicing Fields
  nrsIRN            String?       @unique
  nrsStamp          String?
  nrsQrCode         String?
  nrsSubmittedAt    DateTime?
  nrsAcknowledgedAt DateTime?
  nrsStatus         NRSStatus     @default(PENDING)
  nrsResponse       Json?
  ublXml            String?
  // Payment
  paymentMethod     String?
  paystackRef       String?
  createdById       String?
  pdfUrl            String?
  whatsappSentAt    DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  customer  Customer      @relation(fields: [customerId], references: [id])
  quote     Quote?        @relation(fields: [quoteId], references: [id])
  createdBy User?         @relation("InvoiceCreator", fields: [createdById], references: [id])
  lines     InvoiceLine[]
  payments  Payment[]
  nrsLogs   NRSLog[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, status])
  @@index([nrsStatus])
}

enum InvoiceType {
  B2B
  B2G
  B2C
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
  CREDITED
}

enum NRSStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
  NOT_REQUIRED
}

model InvoiceLine {
  id          String  @id @default(uuid())
  invoiceId   String
  productId   String?
  description String
  quantity    Decimal @db.Decimal(18, 3)
  unitPrice   Decimal @db.Decimal(18, 2)
  vatRate     Decimal @default(0.075) @db.Decimal(5, 4)
  vatAmount   Decimal @db.Decimal(18, 2)
  whtRate     Decimal @default(0) @db.Decimal(5, 4)
  whtAmount   Decimal @default(0) @db.Decimal(18, 2)
  lineTotal   Decimal @db.Decimal(18, 2)

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
}

model Payment {
  id         String        @id @default(uuid())
  tenantId   String
  invoiceId  String
  amount     Decimal       @db.Decimal(18, 2)
  currency   String        @default("NGN")
  method     String
  reference  String?       @unique
  status     PaymentStatus @default(PENDING)
  gateway    String?
  gatewayRef String?
  paidAt     DateTime?
  notes      String?
  createdAt  DateTime      @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// ─────────────────────────────────────────────
// NRS / TAX COMPLIANCE
// ─────────────────────────────────────────────

model NRSLog {
  id           String   @id @default(uuid())
  tenantId     String
  invoiceId    String?
  action       String
  requestUrl   String
  requestBody  Json?
  responseCode Int?
  responseBody Json?
  irn          String?
  status       String
  errorMessage String?
  durationMs   Int?
  createdAt    DateTime @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([tenantId])
  @@index([invoiceId])
  @@index([createdAt])
}

model TaxFiling {
  id          String       @id @default(uuid())
  tenantId    String
  type        TaxType
  period      String
  fromDate    DateTime
  toDate      DateTime
  status      FilingStatus @default(DRAFT)
  vatOutput   Decimal      @default(0) @db.Decimal(18, 2)
  vatInput    Decimal      @default(0) @db.Decimal(18, 2)
  vatPayable  Decimal      @default(0) @db.Decimal(18, 2)
  whtPayable  Decimal      @default(0) @db.Decimal(18, 2)
  filedAt     DateTime?
  referenceNo String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

enum TaxType {
  VAT
  WHT
  PAYE
  CIT
}

enum FilingStatus {
  DRAFT
  SUBMITTED
  ACCEPTED
  REJECTED
}

// ─────────────────────────────────────────────
// HR & PAYROLL
// ─────────────────────────────────────────────

model Employee {
  id                String         @id @default(uuid())
  tenantId          String
  staffId           String
  firstName         String
  lastName          String
  email             String?
  phone             String?
  nin               String?
  bvn               String?
  portalAccessToken         String?   @unique
  portalAccessTokenExpiresAt DateTime?
  dateOfBirth       DateTime?
  gender            String?
  address           String?
  city              String?
  state             String?
  department        String?
  jobTitle          String?
  employmentType    EmploymentType @default(FULL_TIME)
  employmentDate    DateTime
  terminationDate   DateTime?
  isActive          Boolean        @default(true)
  grossSalary       Decimal        @db.Decimal(18, 2)
  bankName          String?
  bankAccountNumber String?
  bankAccountName   String?
  pensionPin        String?
  nhfNumber         String?
  taxId             String?
  payeeTaxBand      Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  payslips Payslip[]

  @@unique([tenantId, staffId])
  @@index([tenantId])
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

model PayrollRun {
  id           String        @id @default(uuid())
  tenantId     String
  period       String
  month        Int
  year         Int
  status       PayrollStatus @default(DRAFT)
  totalGross   Decimal       @db.Decimal(18, 2)
  totalPaye    Decimal       @db.Decimal(18, 2)
  totalPension Decimal       @db.Decimal(18, 2)
  totalNhf     Decimal       @db.Decimal(18, 2)
  totalItf     Decimal       @db.Decimal(18, 2)
  totalNet     Decimal       @db.Decimal(18, 2)
  nibssFile    String?
  processedAt  DateTime?
  createdById  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  payslips Payslip[]

  @@unique([tenantId, month, year])
  @@index([tenantId])
}

enum PayrollStatus {
  DRAFT
  PROCESSING
  APPROVED
  PAID
  CANCELLED
}

model Payslip {
  id              String   @id @default(uuid())
  payrollRunId    String
  employeeId      String
  grossSalary     Decimal  @db.Decimal(18, 2)
  basicSalary     Decimal  @db.Decimal(18, 2)
  housing         Decimal  @default(0) @db.Decimal(18, 2)
  transport       Decimal  @default(0) @db.Decimal(18, 2)
  otherAllowances Decimal  @default(0) @db.Decimal(18, 2)
  payeeTax        Decimal  @db.Decimal(18, 2)
  employeePension Decimal  @db.Decimal(18, 2)
  employerPension Decimal  @db.Decimal(18, 2)
  nhf             Decimal  @default(0) @db.Decimal(18, 2)
  itf             Decimal  @default(0) @db.Decimal(18, 2)
  otherDeductions Decimal  @default(0) @db.Decimal(18, 2)
  netPay          Decimal  @db.Decimal(18, 2)
  createdAt       DateTime @default(now())

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id])

  @@unique([payrollRunId, employeeId])
}

// ─────────────────────────────────────────────
// E-COMMERCE MARKETPLACE
// ─────────────────────────────────────────────

model MarketplaceListing {
  id            String    @id @default(uuid())
  tenantId      String
  productId     String
  title         String
  description   String
  price         Decimal   @db.Decimal(18, 2)
  comparePrice  Decimal?  @db.Decimal(18, 2)
  currency      String    @default("NGN")
  stock         Int       @default(0)
  images        String[]
  tags          String[]
  categoryId    String?
  isActive      Boolean   @default(true)
  isFeatured    Boolean   @default(false)
  rating        Decimal   @default(0) @db.Decimal(3, 2)
  reviewCount   Int       @default(0)
  soldCount     Int       @default(0)
  viewCount     Int       @default(0)
  slug          String    @unique
  searchVector  String?
  weight        Decimal?  @db.Decimal(10, 3)
  dimensions    Json?
  shippingClass String?
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  product    Product                @relation(fields: [productId], references: [id])
  category   ProductCategory?       @relation(fields: [categoryId], references: [id])
  orderLines MarketplaceOrderLine[]
  reviews    ProductReview[]

  @@index([tenantId, isActive])
  @@index([categoryId])
}

model MarketplaceCustomer {
  id                         String    @id @default(uuid())
  email                      String    @unique
  passwordHash               String
  fullName                   String
  phone                      String?
  avatarUrl                  String?
  emailVerified              Boolean   @default(false)
  emailVerificationToken     String?
  emailVerificationExpiresAt DateTime?
  mfaEnabled                 Boolean   @default(false)
  mfaSecret                  String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  wallet                     CustomerWallet?
  platformTickets            PlatformSupportTicket[]
  addresses                  MarketplaceCustomerAddress[]
  transportBookings          TransportBooking[]
  budgetPlans                BudgetPlan[]
}

model MarketplaceCustomerAddress {
  id         String   @id @default(uuid())
  customerId String
  label      String   @default("Address")
  name       String
  phone      String?
  address    String
  city       String?
  state      String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer MarketplaceCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model MarketplaceOrder {
  id                String                 @id @default(uuid())
  orderNumber       String                 @unique
  tenantId          String?
  buyerEmail        String
  buyerPhone        String?
  buyerName         String
  status            MarketplaceOrderStatus @default(PENDING)
  paymentStatus     PaymentStatus          @default(PENDING)
  currency          String                 @default("NGN")
  subtotal          Decimal                @db.Decimal(18, 2)
  shippingCost      Decimal                @default(0) @db.Decimal(18, 2)
  vatAmount         Decimal                @default(0) @db.Decimal(18, 2)
  totalAmount       Decimal                @db.Decimal(18, 2)
  platformFee       Decimal                @default(0) @db.Decimal(18, 2)
  sellerAmount      Decimal                @db.Decimal(18, 2)
  paystackRef       String?
  escrowStatus      EscrowStatus           @default(HELD)
  deliveryAddress   Json
  deliveryMethod    String?
  trackingNumber    String?
  logisticsProvider String?
  logisticsRef      String?
  notes             String?
  paidAt            DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  tenant     Tenant?                @relation(fields: [tenantId], references: [id])
  lines      MarketplaceOrderLine[]
  deliveries Delivery[]
  sellerPayouts MarketplaceSellerPayout[]

  @@index([buyerEmail])
  @@index([status])
}

model MarketplaceSellerPayout {
  id                   String   @id @default(uuid())
  orderId              String
  tenantId             String
  amount               Decimal  @db.Decimal(18, 2)
  currency             String   @default("NGN")
  paystackReference    String?
  paystackTransferCode String?
  status               String   @default("PENDING")
  errorMessage         String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  order  MarketplaceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tenant Tenant           @relation(fields: [tenantId], references: [id])

  @@index([orderId])
  @@index([tenantId])
}

enum MarketplaceOrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  DISPUTED
}

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
  DISPUTED
}

model MarketplaceOrderLine {
  id          String  @id @default(uuid())
  orderId     String
  listingId   String
  tenantId    String
  productName String
  quantity    Int
  unitPrice   Decimal @db.Decimal(18, 2)
  vatAmount   Decimal @db.Decimal(18, 2)
  lineTotal   Decimal @db.Decimal(18, 2)
  commission  Decimal @db.Decimal(18, 2)
  sellerNet   Decimal @db.Decimal(18, 2)

  order   MarketplaceOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  listing MarketplaceListing @relation(fields: [listingId], references: [id])
}

model ProductReview {
  id         String   @id @default(uuid())
  listingId  String
  buyerName  String
  buyerEmail String
  rating     Int
  title      String?
  comment    String?
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())

  listing MarketplaceListing @relation(fields: [listingId], references: [id])
}

// ─────────────────────────────────────────────
// CUSTOMER CARE & CALL CENTER
// ─────────────────────────────────────────────

model SupportTicket {
  id              String         @id @default(uuid())
  tenantId        String
  ticketNumber    String
  customerId      String?
  customerName    String
  customerEmail   String?
  customerPhone   String?
  channel         TicketChannel  @default(EMAIL)
  category        TicketCategory @default(GENERAL)
  priority        TicketPriority @default(MEDIUM)
  status          TicketStatus   @default(OPEN)
  subject         String
  description     String
  assignedToId    String?
  resolvedAt      DateTime?
  closedAt        DateTime?
  firstResponseAt DateTime?
  slaDeadline     DateTime?
  tags            String[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  tenant     Tenant          @relation(fields: [tenantId], references: [id])
  customer   Customer?       @relation(fields: [customerId], references: [id])
  assignedTo User?           @relation("AssignedTickets", fields: [assignedToId], references: [id])
  comments   TicketComment[]
  callLogs   CallLog[]

  @@unique([tenantId, ticketNumber])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model TicketComment {
  id         String   @id @default(uuid())
  ticketId   String
  authorId   String?
  authorName String
  body       String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User?         @relation(fields: [authorId], references: [id])

  @@index([ticketId])
}

model CallLog {
  id              String        @id @default(uuid())
  tenantId        String
  ticketId        String?
  customerId      String?
  customerName    String
  customerPhone   String
  agentId         String?
  direction       CallDirection @default(INBOUND)
  outcome         CallOutcome   @default(CONNECTED)
  durationSeconds Int?
  notes           String?
  recordingUrl    String?
  createdAt       DateTime      @default(now())

  tenant   Tenant         @relation(fields: [tenantId], references: [id])
  ticket   SupportTicket? @relation(fields: [ticketId], references: [id])
  customer Customer?      @relation(fields: [customerId], references: [id])
  agent    User?          @relation("AgentCallLogs", fields: [agentId], references: [id])

  @@index([tenantId, createdAt])
  @@index([ticketId])
}

enum TicketChannel {
  EMAIL
  PHONE
  WHATSAPP
  WALK_IN
  WEB_FORM
  CHAT
}

enum TicketCategory {
  GENERAL
  BILLING
  TECHNICAL
  DELIVERY
  COMPLAINT
  REFUND
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallOutcome {
  CONNECTED
  NO_ANSWER
  VOICEMAIL
  BUSY
  FAILED
}

// ─────────────────────────────────────────────
// PLATFORM SUPPORT (Back Office)
// ─────────────────────────────────────────────

model PlatformSupportTicket {
  id                String        @id @default(uuid())
  ticketNumber      String        @unique
  marketplaceCustomerId String?
  customerEmail     String
  customerName      String?
  subject           String
  description       String
  channel           TicketChannel @default(CHAT)
  category          TicketCategory @default(GENERAL)
  priority          TicketPriority @default(MEDIUM)
  status            TicketStatus   @default(OPEN)
  assignedToAdminId String?
  resolvedAt        DateTime?
  closedAt          DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  marketplaceCustomer MarketplaceCustomer? @relation(fields: [marketplaceCustomerId], references: [id], onDelete: SetNull)
  assignedToAdmin     AdminUser?  @relation("AssignedPlatformTickets", fields: [assignedToAdminId], references: [id], onDelete: SetNull)
  comments            PlatformTicketComment[]

  @@index([status])
  @@index([marketplaceCustomerId])
  @@index([assignedToAdminId])
  @@index([createdAt])
}

model PlatformTicketComment {
  id           String   @id @default(uuid())
  ticketId     String
  authorType   String   // CUSTOMER | AGENT
  authorId     String?  // AdminUser id when AGENT
  authorName   String
  body         String
  isInternal   Boolean  @default(false)
  createdAt    DateTime @default(now())

  ticket PlatformSupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

// ─────────────────────────────────────────────
// CUSTOMER WALLET & ESCROW
// ─────────────────────────────────────────────

model CustomerWallet {
  id            String   @id @default(uuid())
  customerId    String   @unique
  balance       Decimal  @default(0) @db.Decimal(18, 2)
  currency      String   @default("NGN")
  updatedAt     DateTime @updatedAt

  customer   MarketplaceCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@index([customerId])
}

model WalletTransaction {
  id          String   @id @default(uuid())
  walletId    String
  type        String   // DEPOSIT, WITHDRAWAL, PAYMENT, REFUND, ESCROW_HOLD, ESCROW_RELEASE
  amount      Decimal  @db.Decimal(18, 2)
  balanceAfter Decimal? @db.Decimal(18, 2)
  reference   String?  // orderId, escrowId, paymentRef
  status      String   @default("COMPLETED") // PENDING, COMPLETED, FAILED
  createdAt   DateTime @default(now())

  wallet CustomerWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([createdAt])
}

model Escrow {
  id             String   @id @default(uuid())
  orderId        String?
  marketplaceOrderId String?
  buyerCustomerId String
  sellerTenantId  String?
  amount         Decimal  @db.Decimal(18, 2)
  status         String   @default("HELD") // HELD, RELEASED_TO_SELLER, REFUNDED_TO_BUYER
  releasedAt     DateTime?
  createdAt      DateTime @default(now())

  @@index([marketplaceOrderId])
  @@index([buyerCustomerId])
  @@index([status])
}

// ─────────────────────────────────────────────
// MARKETPLACE CUSTOMER UTILITIES: TRANSPORT & BUDGET
// ─────────────────────────────────────────────

model TransportBooking {
  id         String   @id @default(uuid())
  customerId String
  mode       String   // AIR, RAIL, BUS
  from       String
  to         String
  provider   String
  price      Decimal  @db.Decimal(18, 2)
  eta        String?
  status     String   @default("BOOKED") // BOOKED, CANCELLED, COMPLETED
  createdAt  DateTime @default(now())

  customer MarketplaceCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
}

model BudgetPlan {
  id         String   @id @default(uuid())
  customerId String
  month      String   // e.g. "2026-03"
  incomes    Json     // array of { id, label, amount }
  expenses   Json     // array of { id, label, amount }
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer MarketplaceCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, month])
  @@index([customerId])
}

// ─────────────────────────────────────────────
// POINT OF SALE (POS)
// ─────────────────────────────────────────────

model POSSale {
  id             String        @id @default(uuid())
  tenantId       String
  receiptNumber  String
  customerId     String?
  customerName   String?
  cashierId      String
  registerId     String?
  paymentMethod  POSPayMethod  @default(CASH)
  subtotal       Decimal       @db.Decimal(18, 2)
  discountAmount Decimal       @default(0) @db.Decimal(18, 2)
  discountType   String?
  discountValue  Decimal       @default(0) @db.Decimal(18, 2)
  vatAmount      Decimal       @default(0) @db.Decimal(18, 2)
  totalAmount    Decimal       @db.Decimal(18, 2)
  amountTendered Decimal       @default(0) @db.Decimal(18, 2)
  changeDue      Decimal       @default(0) @db.Decimal(18, 2)
  tenders        Json?
  offline        Boolean       @default(false)
  offlineId      String?
  deviceId       String?
  terminalId     String?
  status         POSSaleStatus @default(COMPLETED)
  notes          String?
  voidedAt       DateTime?
  voidedById     String?
  voidReason     String?
  createdAt      DateTime      @default(now())

  tenant   Tenant        @relation(fields: [tenantId], references: [id])
  customer Customer?     @relation(fields: [customerId], references: [id])
  cashier  User          @relation("POSCashier", fields: [cashierId], references: [id])
  lines    POSSaleLine[]

  @@unique([tenantId, receiptNumber])
  @@index([tenantId, createdAt])
  @@index([tenantId, cashierId])
  @@index([offline, createdAt])
  @@index([offlineId])
}

model POSSaleLine {
  id          String  @id @default(uuid())
  saleId      String
  productId   String?
  productName String
  sku         String?
  quantity    Decimal @db.Decimal(18, 3)
  unitPrice   Decimal @db.Decimal(18, 2)
  vatRate     Decimal @default(0.075) @db.Decimal(5, 4)
  vatAmount   Decimal @db.Decimal(18, 2)
  lineTotal   Decimal @db.Decimal(18, 2)

  sale    POSSale  @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
}

enum POSPayMethod {
  CASH
  CARD
  TRANSFER
  SPLIT
}

enum POSSaleStatus {
  COMPLETED
  VOIDED
  REFUNDED
}

// ─────────────────────────────────────────────
// LOGISTICS
// ─────────────────────────────────────────────

model LogisticsCompany {
  id              String          @id @default(uuid())
  name            String
  email           String          @unique
  phone           String?
  password        String
  contactPerson   String?
  address         String?
  city            String?
  state           String?
  coverageAreas   String[]
  logoUrl         String?
  cacNumber       String?
  bankName        String?
  bankAccount     String?
  bankCode        String?
  status          LogisticsStatus @default(PENDING)
  rating          Decimal         @default(0) @db.Decimal(3, 2)
  totalDeliveries Int             @default(0)
  isActive        Boolean         @default(true)
  approvedAt      DateTime?
  approvedById    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  agents     LogisticsAgent[]
  deliveries Delivery[]

  @@index([status])
}

model LogisticsAgent {
  id              String               @id @default(uuid())
  companyId       String?
  tenantId        String?
  firstName       String
  lastName        String
  email           String               @unique
  phone           String
  password        String
  avatarUrl       String?
  agentCode       String?              @unique
  vehicleType     VehicleType?
  vehiclePlate    String?
  coverageZone    String?
  city            String?
  state           String?
  status          LogisticsAgentStatus @default(PENDING)
  rating          Decimal              @default(0) @db.Decimal(3, 2)
  totalDeliveries Int                  @default(0)
  successRate     Decimal              @default(0) @db.Decimal(5, 2)
  isOnline        Boolean              @default(false)
  lastSeenAt      DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  company    LogisticsCompany? @relation(fields: [companyId], references: [id])
  tenant     Tenant?           @relation(fields: [tenantId], references: [id])
  deliveries Delivery[]

  @@index([companyId])
  @@index([status])
  @@index([tenantId])
}

model Delivery {
  id                   String           @id @default(uuid())
  tenantId             String?
  orderId              String?
  orderRef             String?
  invoiceRef           String?
  trackingNumber       String           @unique
  companyId            String?
  agentId              String?
  customerName         String
  customerPhone        String?
  customerEmail        String?
  pickupAddress        String?
  deliveryAddress      String
  city                 String?
  state                String?
  packageDescription   String?
  packageWeight        Decimal?         @db.Decimal(10, 3)
  packageSize          String?
  deliveryFee          Decimal          @default(0) @db.Decimal(18, 2)
  platformCommission   Decimal          @default(0) @db.Decimal(18, 2)
  agentPayout          Decimal          @default(0) @db.Decimal(18, 2)
  status               DeliveryStatus   @default(PENDING_PICKUP)
  priority             DeliveryPriority @default(STANDARD)
  notes                String?
  proofOfDelivery      String?
  failureReason        String?
  pickedUpAt           DateTime?
  inTransitAt          DateTime?
  outForDeliveryAt     DateTime?
  deliveredAt          DateTime?
  failedAt             DateTime?
  expectedDeliveryDate DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  tenant           Tenant?           @relation(fields: [tenantId], references: [id])
  company          LogisticsCompany? @relation(fields: [companyId], references: [id])
  agent            LogisticsAgent?   @relation(fields: [agentId], references: [id])
  marketplaceOrder MarketplaceOrder? @relation(fields: [orderId], references: [id])

  @@index([tenantId])
  @@index([agentId])
  @@index([companyId])
  @@index([status])
  @@index([trackingNumber])
}

enum LogisticsStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

enum LogisticsAgentStatus {
  PENDING
  ACTIVE
  SUSPENDED
  OFFLINE
}

enum VehicleType {
  BIKE
  MOTORCYCLE
  CAR
  VAN
  TRUCK
}

enum DeliveryStatus {
  PENDING_PICKUP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RETURNED
  CANCELLED
}

enum DeliveryPriority {
  EXPRESS
  STANDARD
  ECONOMY
}

// ─────────────────────────────────────────────
// AUDIT TRAIL (IMMUTABLE)
// ─────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String?
  userId      String?
  adminUserId String?
  action      String
  resource    String
  resourceId  String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  tenant    Tenant?    @relation(fields: [tenantId], references: [id])
  user      User?      @relation(fields: [userId], references: [id])
  adminUser AdminUser? @relation(fields: [adminUserId], references: [id])

  @@index([tenantId, createdAt])
  @@index([resource, resourceId])
  @@index([createdAt])
}
