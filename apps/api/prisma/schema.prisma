  lastName          String
  email             String?
  phone             String?
  nin               String?
  bvn               String?
  portalAccessToken         String?   @unique
  portalAccessTokenExpiresAt DateTime?
  dateOfBirth       DateTime?
  gender            String?
  address           String?
  city              String?
  state             String?
  department        String?
  jobTitle          String?
  employmentType    EmploymentType @default(FULL_TIME)
  employmentDate    DateTime
  terminationDate   DateTime?
  isActive          Boolean        @default(true)
