// Cosmos ERP - Prisma Schema
// Multi-tenant Nigerian ERP Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ─────────────────────────────────────────────
// SUPER ADMIN / PLATFORM LAYER
// ─────────────────────────────────────────────

model Platform {
  id                 String   @id @default(uuid())
  name               String   @default("Cosmos ERP")
  commissionRate     Decimal  @default(0.05) @db.Decimal(5, 4)
  vatRate            Decimal  @default(0.075) @db.Decimal(5, 4)
  currency           String   @default("NGN")
  featureFlags       Json?
  maintenanceMode    Boolean  @default(false)
  maintenanceMessage String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

/// Anonymous page views from the public site (marketplace, etc.) for admin analytics.
model SiteVisit {
  id              String   @id @default(uuid())
  createdAt       DateTime @default(now())
  path            String   @db.VarChar(2048)
  referrer        String?  @db.VarChar(2048)
  pageTitle       String?  @db.VarChar(500)
  sessionId       String?  @db.VarChar(64)
  ip              String   @db.VarChar(45)
  userAgent       String?  @db.Text
  browserName     String?  @db.VarChar(64)
  browserVersion  String?  @db.VarChar(32)
  osName          String?  @db.VarChar(64)
  osVersion       String?  @db.VarChar(32)
  deviceType      String?  @db.VarChar(32)
  deviceVendor    String?  @db.VarChar(64)
  deviceModel     String?  @db.VarChar(64)
  countryCode     String?  @db.VarChar(2)
  countryName     String?  @db.VarChar(100)
  region          String?  @db.VarChar(128)
  city            String?  @db.VarChar(128)
  latitude        Float?
  longitude       Float?

  @@index([createdAt])
  @@index([path])
  @@index([countryCode])
  @@index([deviceType])
  @@index([browserName])
  @@index([osName])
}

model AdminUser {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  firstName    String
  lastName     String
  role         AdminRole  @default(SUPPORT)
  isActive     Boolean    @default(true)
  lastLoginAt  DateTime?
  mfaEnabled   Boolean    @default(false)
  mfaSecret   String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
  assignedPlatformTickets PlatformSupportTicket[] @relation("AssignedPlatformTickets")
}

enum AdminRole {
  SUPER_ADMIN
  FINANCE_ADMIN
  SUPPORT
  COMPLIANCE
}

// ─────────────────────────────────────────────
// TENANT (Business) LAYER
// ─────────────────────────────────────────────

model Tenant {
  id                  String           @id @default(uuid())
  businessName        String
  tradingName         String?
  tin                 String?          @unique
  rcNumber            String?
  email               String           @unique
  phone               String
  address             String
  city                String
  state               String
  country             String           @default("Nigeria")
  logoUrl             String?
  website             String?
  invoiceTemplate     InvoiceTemplate  @default(CLASSIC)
  businessType        BusinessType     @default(SOLE_PROPRIETORSHIP)
  industry            String?
  kycStatus           KYCStatus        @default(PENDING)
  kycDocuments        Json?
  kycFormData         Json?
  kycRejectionReason  String?
  kycVerifiedAt       DateTime?
  kycVerifiedBy       String?
  isActive            Boolean          @default(true)
  isMarketplaceSeller Boolean          @default(false)
  enabledModules      Json?
  subscriptionPlan    SubscriptionPlan @default(STARTER)
  subscriptionStatus  SubStatus        @default(TRIAL)
  trialEndsAt         DateTime?
  subscriptionEndsAt  DateTime?
  nrsTaxpayerId       String?
  nrsRegisteredAt     DateTime?
  bankName            String?
  bankAccountNumber   String?
  bankAccountName     String?
  bankSortCode        String?
  paystackRecipientCode String?        // cached Paystack transfer recipient code (NGN payouts)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  onboardedByAgentId  String?
  onboardedBy         User?            @relation("OnboardedTenants", fields: [onboardedByAgentId], references: [id])

  users             User[]
  products          Product[]
  customers         Customer[]
  suppliers         Supplier[]
  invoices          Invoice[]
  invoiceReminders  InvoiceReminder[]
  invoiceImports    InvoiceImport[]
  invoiceOCRData    InvoiceOCRData[]
  recurringInvoices RecurringInvoice[]
  invoiceApprovals  InvoiceApprovalWorkflow[]
  invoiceDuplicateChecks InvoiceDuplicateCheck[]
  invoiceNumbering  InvoiceNumbering?
  quotes            Quote[]
  purchaseOrders    PurchaseOrder[]
  vendorBills       VendorBill[]
  vendorBillPayments VendorBillPayment[]
  vendorBillPaymentSchedules VendorBillPaymentSchedule[]
  warehouses        Warehouse[]
  employees         Employee[]
  payrollRuns       PayrollRun[]
  accounts          Account[]
  journalEntries    JournalEntry[]
  budgets           Budget[]
  budgetLines       BudgetLine[]
  taxFilings        TaxFiling[]
  subscriptions     Subscription[]
  marketplaceOrders MarketplaceOrder[]
  auditLogs         AuditLog[]
  nrsLogs           NRSLog[]
  currencies        TenantCurrency[]
  supportTickets    SupportTicket[]
  callLogs          CallLog[]
  posSales          POSSale[]
  logisticsAgents   LogisticsAgent[]
  deliveries        Delivery[]
  kycDocumentFiles  KycDocument[]
  accountingPeriods AccountingPeriod[]
  marketplaceSellerPayouts MarketplaceSellerPayout[]

  departments       Department[]
  announcements     Announcement[]
  announcementAcks  AnnouncementAck[]

  projects          Project[]
  projectMembers    ProjectMember[]
  tasks             Task[]

  employeeDocuments EmployeeDocument[]
  leaveRequests     LeaveRequest[]
  resignations      Resignation[]
  intranetMessages  IntranetMessage[]
  goodsReceivedNotes GoodsReceivedNote[] @relation("GRNs")
  poAmendments      PurchaseOrderAmendment[] @relation("POAmendments")
  poMatchings       POMatching[] @relation("POMatchings")

  @@index([kycStatus])
  @@index([subscriptionStatus])
  @@index([onboardedByAgentId])
}

enum BusinessType {
  SOLE_PROPRIETORSHIP
  PARTNERSHIP
  LIMITED_LIABILITY
  PUBLIC_LIMITED
  NGO
  GOVERNMENT
}

enum InvoiceTemplate {
  CLASSIC
  MODERN
  COMPACT
  BLUE
  MINIMAL
}

enum KYCStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum KycDocumentType {
  CAC_CERTIFICATE
  CAC_PARTICULARS
  CAC_FORM
  DIRECTOR_ID
  DIRECTOR_PHOTO
  PROOF_OF_ADDRESS
  UTILITY_BILL
  BANK_STATEMENT
  TAX_CLEARANCE
  OTHER
}

model KycDocument {
  id           String          @id @default(uuid())
  tenantId     String
  documentType KycDocumentType
  filePath     String
  fileName     String
  mimeType     String?
  fileSize     Int?
  notes        String?
  uploadedById String?
  uploadedAt   DateTime        @default(now())

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy User?  @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([documentType])
}

enum SubscriptionPlan {
  STARTER
  GROWTH
  ENTERPRISE
}

enum SubStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  SUSPENDED
}

model Subscription {
  id              String           @id @default(uuid())
  tenantId        String
  plan            SubscriptionPlan
  status          SubStatus
  billingCycle    BillingCycle     @default(MONTHLY)
  amount          Decimal          @db.Decimal(12, 2)
  currency        String           @default("NGN")
  startDate       DateTime
  endDate         DateTime?
  nextBillingDate DateTime?
  paystackSubCode String?
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  tenant   Tenant                @relation(fields: [tenantId], references: [id])
  payments SubscriptionPayment[]

  @@index([tenantId])
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

model SubscriptionPayment {
  id             String        @id @default(uuid())
  subscriptionId String
  amount         Decimal       @db.Decimal(12, 2)
  currency       String        @default("NGN")
  status         PaymentStatus
  reference      String        @unique
  gateway        String
  paidAt         DateTime?
  metadata       Json?
  createdAt      DateTime      @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id])
}

// ─────────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole  @default(STAFF)
  permissions  Json?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  avatarUrl    String?
  phone        String?
  mfaEnabled   Boolean   @default(false)
  mfaSecret   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant               Tenant          @relation(fields: [tenantId], references: [id])
  createdInvoices      Invoice[]       @relation("InvoiceCreator")
  auditLogs            AuditLog[]
  refreshTokens        RefreshToken[]
  webAuthnCredentials  WebAuthnCredential[]
  webAuthnChallenges   WebAuthnChallenge[]
  assignedTickets      SupportTicket[] @relation("AssignedTickets")
  ticketComments       TicketComment[]
  agentCallLogs        CallLog[]       @relation("AgentCallLogs")
  posCashierSales      POSSale[]       @relation("POSCashier")
  onboardedTenants     Tenant[]        @relation("OnboardedTenants")
  kycDocumentsUploaded KycDocument[]
  closedAccountingPeriods AccountingPeriod[]

  announcementAcks     AnnouncementAck[]

  managedDepartments   Department[]  @relation("DepartmentManager")
  announcementsCreated Announcement[] @relation("AnnouncementCreator")

  projectsCreated      Project[]       @relation("ProjectCreator")
  projectMemberships   ProjectMember[]

  tasksCreated         Task[]          @relation("TaskCreator")
  assignedTasks        Task[]          @relation("TaskAssignee")

  employeeProfile      Employee?

  uploadedEmployeeDocuments EmployeeDocument[] @relation("EmployeeDocumentUploader")
  decidedLeaveRequests      LeaveRequest[]     @relation("LeaveRequestDecider")
  decidedResignations       Resignation[]      @relation("ResignationDecider")

  intranetMessagesSent      IntranetMessage[]  @relation("IntranetMessageSender")
  intranetMessagesReceived  IntranetMessage[]  @relation("IntranetMessageRecipient")

  @@unique([tenantId, email])
  @@index([tenantId])
}

// ─────────────────────────────────────────────
// ORG STRUCTURE + INTERNAL COMMS
// ─────────────────────────────────────────────

model Department {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  code      String?
  managerId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  manager User?  @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)

  announcements Announcement[]

  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId])
}

enum AnnouncementAudienceType {
  ALL
  ROLE
  DEPARTMENT
  USERS
}

model Announcement {
  id           String                   @id @default(uuid())
  tenantId     String
  title        String
  body         String
  audienceType AnnouncementAudienceType @default(ALL)
  audienceRole UserRole?
  departmentId String?
  userIds      String[]
  publishAt    DateTime?
  expiresAt    DateTime?
  createdById  String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdBy  User?       @relation("AnnouncementCreator", fields: [createdById], references: [id], onDelete: SetNull)
  acks       AnnouncementAck[]

  @@index([tenantId])
  @@index([publishAt])
  @@index([expiresAt])
}

model AnnouncementAck {
  id             String   @id @default(uuid())
  tenantId       String
  announcementId String
  userId         String
  readAt         DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([tenantId])
  @@index([userId])
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectMemberRole {
  OWNER
  MANAGER
  MEMBER
}

model Project {
  id          String        @id @default(uuid())
  tenantId    String
  name        String
  code        String?
  description String?
  status      ProjectStatus @default(ACTIVE)
  startDate   DateTime?
  endDate     DateTime?
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?         @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: SetNull)
  members   ProjectMember[]

  tasks     Task[]

  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([status])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id          String       @id @default(uuid())
  tenantId    String
  projectId   String
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  assigneeId  String?
  createdById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy User?  @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
}

model ProjectMember {
  id        String            @id @default(uuid())
  tenantId  String
  projectId String
  userId    String
  role      ProjectMemberRole @default(MEMBER)
  createdAt DateTime          @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([tenantId])
  @@index([userId])
}

enum UserRole {
  OWNER
  ADMIN
  ACCOUNTANT
  SALES
  WAREHOUSE
  HR
  STAFF
  VIEWER
  FIELD_AGENT
  CRM_MANAGER
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

model Lead {
  id              String    @id @default(uuid())
  tenantId        String
  firstName       String
  lastName        String?
  company         String?
  email           String?
  phone           String?
  source          String?
  stage           LeadStage @default(NEW)
  estimatedValue  Decimal?  @db.Decimal(18, 2)
  nextFollowUpAt  DateTime?
  notes           String?
  assignedToId    String?
  convertedAt     DateTime?
  convertedById   String?
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId, stage, createdAt])
  @@index([tenantId, assignedToId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WebAuthnCredential {
  id             String   @id @default(uuid())
  userId         String
  credentialId   String   @unique
  publicKey      String
  counter        Int      @default(0)
  transports     Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WebAuthnChallenge {
  id        String   @id @default(uuid())
  userId    String
  type      String
  challenge String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────
// FINANCE — CHART OF ACCOUNTS
// ─────────────────────────────────────────────

model Account {
  id              String      @id @default(uuid())
  tenantId        String
  code            String
  name            String
  type            AccountType
  subType         String?
  description     String?
  currency        String      @default("NGN")
  balance         Decimal     @default(0) @db.Decimal(18, 2)
  isSystemAccount Boolean     @default(false)
  isActive        Boolean     @default(true)
  parentId        String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  parent       Account?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  children     Account[]     @relation("AccountHierarchy")
  journalLines JournalLine[]
  budgetLines  BudgetLine[]

  @@unique([tenantId, code])
  @@index([tenantId, type])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model JournalEntry {
  id           String        @id @default(uuid())
  tenantId     String
  reference    String
  description  String
  date         DateTime
  currency     String        @default("NGN")
  exchangeRate Decimal       @default(1) @db.Decimal(18, 6)
  status       JournalStatus @default(DRAFT)
  sourceType   String?
  sourceId     String?
  createdById  String?
  postedAt     DateTime?
  reversesEntryId String?    @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  lines        JournalLine[]
  reversesEntry JournalEntry? @relation("JournalReversals", fields: [reversesEntryId], references: [id])
  reversedBy    JournalEntry[] @relation("JournalReversals")

  @@index([tenantId, date])
  @@index([sourceType, sourceId])
}

enum JournalStatus {
  DRAFT
  POSTED
  REVERSED
}

model JournalLine {
  id             String   @id @default(uuid())
  journalEntryId String
  accountId      String
  description    String?
  debit          Decimal  @default(0) @db.Decimal(18, 2)
  credit         Decimal  @default(0) @db.Decimal(18, 2)
  createdAt      DateTime @default(now())

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])
}

model AccountingPeriod {
  id         String   @id @default(uuid())
  tenantId   String
  name       String
  startDate  DateTime
  endDate    DateTime
  isClosed   Boolean  @default(false)
  closedAt   DateTime?
  closedById String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  closedBy User?  @relation(fields: [closedById], references: [id])

  @@unique([tenantId, startDate])
  @@index([tenantId, startDate])
  @@index([tenantId, isClosed])
}

enum BudgetStatus {
  DRAFT
  APPROVED
  LOCKED
}

enum BudgetLineCategory {
  OPEX
  CAPEX
  HEADCOUNT
  SALARY
  PROJECT
}

model Budget {
  id          String       @id @default(uuid())
  tenantId    String
  name        String
  fiscalYear  Int
  startDate   DateTime
  endDate     DateTime
  status      BudgetStatus @default(DRAFT)
  notes       String?
  createdById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant Tenant       @relation(fields: [tenantId], references: [id])
  lines  BudgetLine[]

  @@index([tenantId, fiscalYear])
  @@unique([tenantId, name, fiscalYear])
}

model BudgetLine {
  id             String             @id @default(uuid())
  tenantId       String
  budgetId       String
  accountId      String
  month          Int
  amount         Decimal            @db.Decimal(18, 2)
  category       BudgetLineCategory @default(OPEX)
  costCenter     String             @default("")
  projectCode    String             @default("")
  headcount      Int?
  allocationMode String?
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  budget  Budget  @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id])

  @@index([tenantId, budgetId])
  @@index([tenantId, accountId, month])
  @@index([tenantId, category])
  @@index([tenantId, costCenter])
  @@index([tenantId, projectCode])
  @@unique([budgetId, accountId, month, category, costCenter, projectCode])
}

model TenantCurrency {
  id           String   @id @default(uuid())
  tenantId     String
  code         String
  name         String
  symbol       String
  exchangeRate Decimal  @db.Decimal(18, 6)
  isBase       Boolean  @default(false)
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
}

// ─────────────────────────────────────────────
// CUSTOMERS & SUPPLIERS
// ─────────────────────────────────────────────

model Customer {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  email       String?
  phone       String?
  whatsapp    String?
  address     String?
  city        String?
  state       String?
  country     String   @default("Nigeria")
  tin         String?
  rcNumber    String?
  creditLimit Decimal  @default(0) @db.Decimal(18, 2)
  creditUsed  Decimal  @default(0) @db.Decimal(18, 2)
  currency    String   @default("NGN")
  isActive    Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  invoices       Invoice[]
  quotes         Quote[]
  supportTickets SupportTicket[]
  callLogs       CallLog[]
  posSales       POSSale[]

  @@index([tenantId])
}

// ─────────────────────────────────────────────
// VENDOR CATEGORIES & TYPES
// ─────────────────────────────────────────────

enum VendorCategory {
  SUPPLIER
  CONTRACTOR
  UTILITY
  SERVICE_PROVIDER
  LOGISTICS
  OTHER
}

enum VendorRating {
  EXCELLENT
  GOOD
  AVERAGE
  POOR
}

model Supplier {
  id                String          @id @default(uuid())
  tenantId          String
  name              String
  email             String?
  phone             String?
  address           String?
  city              String?
  state             String?
  country           String          @default("Nigeria")
  tin               String?
  currency          String          @default("NGN")
  paymentTerms      Int             @default(30)
  
  // Vendor categorization
  category          VendorCategory  @default(SUPPLIER)
  
  // Bank account & payment details
  bankName          String?
  bankAccountNumber String?
  bankCode          String?
  accountHolderName String?
  
  // Vendor status
  isActive          Boolean         @default(true)
  isBlacklisted     Boolean         @default(false)
  blacklistReason   String?
  blacklistedAt     DateTime?
  
  // Performance tracking
  performanceRating VendorRating    @default(AVERAGE)
  totalOrders       Int             @default(0)
  onTimeDeliveries  Int             @default(0)
  qualityIssues     Int             @default(0)
  
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  purchaseOrders PurchaseOrder[]
  vendorBills    VendorBill[]
  ratings        VendorPerformanceRating[]

  @@index([tenantId])
  @@index([isBlacklisted])
}

model VendorPerformanceRating {
  id         String   @id @default(uuid())
  tenantId   String
  supplierId String
  rating     VendorRating
  feedback   String?
  ratedAt    DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
}

// ─────────────────────────────────────────────
// INVENTORY & PRODUCTS
// ─────────────────────────────────────────────

model Warehouse {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  code      String
  address   String?
  city      String?
  state     String?
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  grns        GoodsReceivedNote[]
  stockLevels StockLevel[]
  stockMoves  StockMovement[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model ProductCategory {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  parentId    String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  parent   ProductCategory?     @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ProductCategory[]    @relation("CategoryHierarchy")
  products Product[]
  listings MarketplaceListing[]
}

model Product {
  id              String   @id @default(uuid())
  tenantId        String
  categoryId      String?
  sku             String
  barcode         String?
  name            String
  description     String?
  unit            String   @default("piece")
  costPrice       Decimal  @db.Decimal(18, 2)
  sellingPrice    Decimal  @db.Decimal(18, 2)
  currency        String   @default("NGN")
  vatRate         Decimal  @default(0.075) @db.Decimal(5, 4)
  whtRate         Decimal  @default(0) @db.Decimal(5, 4)
  reorderPoint    Int      @default(10)
  reorderQty      Int      @default(50)
  weight          Decimal? @db.Decimal(10, 3)
  dimensions      Json?
  images          String[]
  isActive        Boolean  @default(true)
  isMarketplace   Boolean  @default(false)
  marketplaceDesc String?
  landedCost      Decimal  @default(0) @db.Decimal(18, 2)
  hscode          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  category            ProductCategory?     @relation(fields: [categoryId], references: [id])
  stockLevels         StockLevel[]
  stockMoves          StockMovement[]
  invoiceLines        InvoiceLine[]
  quoteLInes          QuoteLine[]
  poLines             PurchaseOrderLine[]
  vendorBillLines     VendorBillLine[]
  landedCosts         LandedCost[]
  marketplaceListings MarketplaceListing[]
  posSaleLines        POSSaleLine[]

  @@unique([tenantId, sku])
  @@unique([tenantId, barcode])
  @@index([tenantId])
  @@index([isMarketplace])
}

model StockLevel {
  id          String   @id @default(uuid())
  tenantId    String
  productId   String
  warehouseId String
  quantity    Int      @default(0)
  reservedQty Int      @default(0)
  updatedAt   DateTime @updatedAt

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@index([tenantId])
}

enum PricingRuleType {
  PERCENT
  FIXED
}

model PricingRule {
  id             String          @id @default(uuid())
  tenantId       String
  name           String
  description    String?
  ruleType       PricingRuleType
  value          Decimal         @db.Decimal(18, 2)
  minSubtotal    Decimal?        @db.Decimal(18, 2)
  productIds     String[]
  categoryIds    String[]
  startAt        DateTime?
  endAt          DateTime?
  isActive       Boolean         @default(true)
  stackable      Boolean         @default(false)
  maxDiscount    Decimal?        @db.Decimal(18, 2)
  createdById    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([tenantId, isActive])
}

model PromotionCode {
  id             String          @id @default(uuid())
  tenantId       String
  code           String
  name           String?
  description    String?
  ruleType       PricingRuleType
  value          Decimal         @db.Decimal(18, 2)
  minSubtotal    Decimal?        @db.Decimal(18, 2)
  usageLimit     Int?
  usageCount     Int             @default(0)
  startAt        DateTime?
  endAt          DateTime?
  isActive       Boolean         @default(true)
  maxDiscount    Decimal?        @db.Decimal(18, 2)
  createdById    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
}

model StockMovement {
  id          String        @id @default(uuid())
  tenantId    String
  productId   String
  warehouseId String
  type        StockMoveType
  quantity    Int
  reference   String?
  sourceId    String?
  sourceType  String?
  notes       String?
  createdById String?
  createdAt   DateTime      @default(now())

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@index([tenantId, productId])
  @@index([sourceType, sourceId])
}

enum StockMoveType {
  PURCHASE_RECEIPT
  SALE_DELIVERY
  TRANSFER
  ADJUSTMENT
  RETURN
  DAMAGE
  OPENING_STOCK
}

model LandedCost {
  id          String   @id @default(uuid())
  tenantId    String
  productId   String
  poId        String?
  description String
  amount      Decimal  @db.Decimal(18, 2)
  currency    String   @default("NGN")
  costType    String
  date        DateTime
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
}

// ─────────────────────────────────────────────
// PURCHASE ORDERS
// ─────────────────────────────────────────────

model PurchaseOrder {
  id              String    @id @default(uuid())
  tenantId        String
  supplierId      String
  poNumber        String
  status          POStatus  @default(DRAFT)
  issueDate       DateTime  @default(now())
  expectedDate    DateTime?
  currency        String    @default("NGN")
  exchangeRate    Decimal   @default(1) @db.Decimal(18, 6)
  subtotal        Decimal   @db.Decimal(18, 2)
  vatAmount       Decimal   @default(0) @db.Decimal(18, 2)
  whtAmount       Decimal   @default(0) @db.Decimal(18, 2)
  totalAmount     Decimal   @db.Decimal(18, 2)
  notes           String?
  isAutoGenerated Boolean   @default(false)
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant   Tenant              @relation(fields: [tenantId], references: [id])
  supplier Supplier            @relation(fields: [supplierId], references: [id])
  lines    PurchaseOrderLine[]
  grns     GoodsReceivedNote[]
  amendments PurchaseOrderAmendment[]
  matchings  POMatching[]

  @@unique([tenantId, poNumber])
  @@index([tenantId])
}

enum POStatus {
  DRAFT
  SENT
  PARTIAL
  RECEIVED
  CANCELLED
}

model PurchaseOrderLine {
  id          String  @id @default(uuid())
  poId        String
  productId   String
  description String?
  quantity    Int
  unitPrice   Decimal @db.Decimal(18, 2)
  vatRate     Decimal @default(0.075) @db.Decimal(5, 4)
  vatAmount   Decimal @db.Decimal(18, 2)
  lineTotal   Decimal @db.Decimal(18, 2)
  receivedQty Int     @default(0)

  po      PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id])
  vendorBillLines VendorBillLine[]
  grnLines GRNLine[]
}

// ─────────────────────────────────────────────
// GOODS RECEIVED NOTES (GRN) & PO MATCHING
// ─────────────────────────────────────────────

model GoodsReceivedNote {
  id              String   @id @default(uuid())
  tenantId        String
  poId            String
  grnNumber       String   @unique
  receiptDate     DateTime @default(now())
  warehouseId     String?
  notes           String?
  status          GRNStatus @default(PENDING) // PENDING, PARTIAL, COMPLETE, REJECTED
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant       Tenant             @relation("GRNs", fields: [tenantId], references: [id])
  po           PurchaseOrder      @relation(fields: [poId], references: [id], onDelete: Cascade)
  warehouse    Warehouse?         @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  lines        GRNLine[]
  matchings    POMatching[]

  @@index([tenantId])
  @@index([poId])
}

model GRNLine {
  id          String @id @default(uuid())
  grnId       String
  poLineId    String
  quantity    Int
  receivedQty Int @default(0)
  notes       String?

  grn    GoodsReceivedNote @relation(fields: [grnId], references: [id], onDelete: Cascade)
  poLine PurchaseOrderLine @relation(fields: [poLineId], references: [id], onDelete: Cascade)
}

model PurchaseOrderAmendment {
  id              String   @id @default(uuid())
  tenantId        String
  poId            String
  amendmentNumber String
  amendmentType   AmendmentType // QUANTITY_CHANGE, PRICE_CHANGE, DATE_CHANGE, CANCELLATION
  originalValue   String?
  newValue        String?
  reason          String?
  status          AmendmentStatus @default(PENDING) // PENDING, APPROVED, REJECTED, IMPLEMENTED
  approvedBy      String?
  approvedAt      DateTime?
  implementedAt   DateTime?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant        @relation("POAmendments", fields: [tenantId], references: [id])
  po     PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([poId])
}

model POMatching {
  id                    String   @id @default(uuid())
  tenantId              String
  poId                  String
  grnId                 String?
  invoiceId             String?
  matchingType          MatchingType // TWO_WAY (PO vs Invoice), THREE_WAY (PO vs GRN vs Invoice), GRN_ONLY, PARTIAL
  poLineId              String?
  grnLineId             String?
  invoiceLineId         String?
  poQuantity            Int?
  grnQuantity           Int?
  invoiceQuantity       Int?
  poAmount              Decimal? @db.Decimal(18, 2)
  grnAmount             Decimal? @db.Decimal(18, 2)
  invoiceAmount         Decimal? @db.Decimal(18, 2)
  matchStatus           MatchStatus // MATCHED, PARTIAL_MATCH, UNMATCHED, VARIANCE, REJECTED
  varianceReason        String?
  variancePercentage    Decimal? @db.Decimal(5, 2) // Percentage difference
  approvedBy            String?
  approvalNotes         String?
  approvedAt            DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant       Tenant                 @relation("POMatchings", fields: [tenantId], references: [id])
  po           PurchaseOrder          @relation(fields: [poId], references: [id], onDelete: Cascade)
  grn          GoodsReceivedNote?     @relation(fields: [grnId], references: [id], onDelete: SetNull)
  invoice      VendorBill?            @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([poId])
  @@index([grnId])
  @@index([invoiceId])
}

enum GRNStatus {
  PENDING
  PARTIAL
  COMPLETE
  REJECTED
}

enum AmendmentType {
  QUANTITY_CHANGE
  PRICE_CHANGE
  DATE_CHANGE
  CANCELLATION
  OTHER
}

enum AmendmentStatus {
  PENDING
  APPROVED
  REJECTED
  IMPLEMENTED
}

enum MatchingType {
  TWO_WAY      // PO vs Invoice
  THREE_WAY    // PO vs GRN vs Invoice
  GRN_ONLY     // GRN linkage only
  PARTIAL      // Partial delivery/invoice
}

enum MatchStatus {
  MATCHED
  PARTIAL_MATCH
  UNMATCHED
  VARIANCE
  REJECTED
}

// ─────────────────────────────────────────────
// ACCOUNTS PAYABLE (Vendor Bills)
// ─────────────────────────────────────────────

enum VendorBillStatus {
  DRAFT
  POSTED
  PARTIAL
  PAID
  CANCELLED
}

enum VendorBillLineMatchStatus {
  UNMATCHED
  MATCHED
  PARTIAL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BillScheduleStatus {
  PENDING
  PAID
  CANCELLED
}

model VendorBill {
  id             String          @id @default(uuid())
  tenantId       String
  supplierId     String
  billNumber     String         // human-readable vendor bill reference (unique per tenant)
  billDate       DateTime       @default(now())
  dueDate        DateTime
  currency       String         @default("NGN")
  exchangeRate   Decimal        @default(1) @db.Decimal(18, 6)

  status         VendorBillStatus @default(DRAFT)
  subtotal       Decimal        @db.Decimal(18, 2)
  vatAmount      Decimal        @default(0) @db.Decimal(18, 2)
  whtAmount      Decimal        @default(0) @db.Decimal(18, 2)
  totalAmount    Decimal        @db.Decimal(18, 2)
  amountPaid     Decimal        @default(0) @db.Decimal(18, 2)
  amountDue      Decimal        @db.Decimal(18, 2)
  approvalStatus ApprovalStatus @default(PENDING)

  notes          String?
  approvalNote   String?
  rejectionReason String?
  approvalRequestedAt DateTime?
  approvedAt     DateTime?
  approvedById   String?
  postedAt       DateTime?
  createdById    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  lines    VendorBillLine[]
  payments VendorBillPayment[]
  paymentSchedules VendorBillPaymentSchedule[]
  matchings POMatching[]

  @@unique([tenantId, billNumber])
  @@index([tenantId, supplierId])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
}

model VendorBillLine {
  id            String                @id @default(uuid())
  billId        String
  poLineId      String?
  productId     String?

  description   String
  quantity      Decimal              @db.Decimal(18, 3)
  unitPrice     Decimal              @db.Decimal(18, 2)

  vatRate       Decimal              @default(0.075) @db.Decimal(5, 4)
  vatAmount     Decimal              @db.Decimal(18, 2)

  whtRate       Decimal              @default(0) @db.Decimal(5, 4)
  whtAmount     Decimal              @db.Decimal(18, 2)

  lineSubtotal  Decimal              @db.Decimal(18, 2)
  lineTotal     Decimal              @db.Decimal(18, 2)

  matchedQty    Decimal              @db.Decimal(18, 3)
  matchStatus   VendorBillLineMatchStatus @default(UNMATCHED)

  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  bill           VendorBill         @relation(fields: [billId], references: [id], onDelete: Cascade)
  poLine         PurchaseOrderLine? @relation(fields: [poLineId], references: [id], onDelete: SetNull)
  product        Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([billId])
  @@index([poLineId])
  @@index([matchStatus])
}

model VendorBillPayment {
  id           String        @id @default(uuid())
  tenantId     String
  billId       String

  amount       Decimal       @db.Decimal(18, 2)
  currency     String        @default("NGN")
  exchangeRate Decimal       @default(1) @db.Decimal(18, 6)
  method       String?
  reference    String?       @unique
  status       PaymentStatus @default(SUCCESS)
  gateway      String?
  gatewayRef   String?
  paidAt       DateTime?
  notes        String?

  createdAt    DateTime     @default(now())

  tenant   Tenant      @relation(fields: [tenantId], references: [id])
  bill     VendorBill  @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([tenantId, billId])
}

model VendorBillPaymentSchedule {
  id          String           @id @default(uuid())
  tenantId    String
  billId      String
  amount      Decimal          @db.Decimal(18, 2)
  dueDate     DateTime
  status      BillScheduleStatus @default(PENDING)
  notes       String?
  paidAt      DateTime?
  createdById String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  tenant Tenant     @relation(fields: [tenantId], references: [id])
  bill   VendorBill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([tenantId, dueDate, status])
  @@index([billId])
}

// ─────────────────────────────────────────────
// SALES — QUOTES & INVOICES (NRS E-INVOICING)
// ─────────────────────────────────────────────

model Quote {
  id             String      @id @default(uuid())
  tenantId       String
  customerId     String
  quoteNumber    String
  status         QuoteStatus @default(DRAFT)
  issueDate      DateTime    @default(now())
  expiryDate     DateTime?
  currency       String      @default("NGN")
  exchangeRate   Decimal     @default(1) @db.Decimal(18, 6)
  subtotal       Decimal     @db.Decimal(18, 2)
  vatAmount      Decimal     @default(0) @db.Decimal(18, 2)
  discountAmount Decimal     @default(0) @db.Decimal(18, 2)
  totalAmount    Decimal     @db.Decimal(18, 2)
  notes          String?
  terms          String?
  createdById    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id])
  customer Customer    @relation(fields: [customerId], references: [id])
  lines    QuoteLine[]
  invoice  Invoice?

  @@unique([tenantId, quoteNumber])
  @@index([tenantId])
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

model QuoteLine {
  id          String  @id @default(uuid())
  quoteId     String
  productId   String?
  description String
  quantity    Decimal @db.Decimal(18, 3)
  unitPrice   Decimal @db.Decimal(18, 2)
  vatRate     Decimal @default(0.075) @db.Decimal(5, 4)
  vatAmount   Decimal @db.Decimal(18, 2)
  whtRate     Decimal @default(0) @db.Decimal(5, 4)
  whtAmount   Decimal @default(0) @db.Decimal(18, 2)
  lineTotal   Decimal @db.Decimal(18, 2)

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
}

model Invoice {
  id                String        @id @default(uuid())
  tenantId          String
  customerId        String
  quoteId           String?       @unique
  invoiceNumber     String
  invoiceType       InvoiceType   @default(B2B)
  status            InvoiceStatus @default(DRAFT)
  issueDate         DateTime      @default(now())
  dueDate           DateTime
  currency          String        @default("NGN")
  exchangeRate      Decimal       @default(1) @db.Decimal(18, 6)
  subtotal          Decimal       @db.Decimal(18, 2)
  vatAmount         Decimal       @default(0) @db.Decimal(18, 2)
  whtAmount         Decimal       @default(0) @db.Decimal(18, 2)
  discountAmount    Decimal       @default(0) @db.Decimal(18, 2)
  totalAmount       Decimal       @db.Decimal(18, 2)
  amountPaid        Decimal       @default(0) @db.Decimal(18, 2)
  amountDue         Decimal       @db.Decimal(18, 2)
  notes             String?
  terms             String?
  // NRS E-Invoicing Fields
  nrsIRN            String?       @unique
  nrsStamp          String?
  nrsQrCode         String?
  nrsSubmittedAt    DateTime?
  nrsAcknowledgedAt DateTime?
  nrsStatus         NRSStatus     @default(PENDING)
  nrsResponse       Json?
  ublXml            String?
  // Payment
  paymentMethod     String?
  paystackRef       String?
  createdById       String?
  pdfUrl            String?
  whatsappSentAt    DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  customer  Customer      @relation(fields: [customerId], references: [id])
  quote     Quote?        @relation(fields: [quoteId], references: [id])
  createdBy User?         @relation("InvoiceCreator", fields: [createdById], references: [id])
  lines     InvoiceLine[]
  payments  Payment[]
  nrsLogs   NRSLog[]
  reminders InvoiceReminder[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, status])
  @@index([nrsStatus])
}

enum InvoiceType {
  B2B
  B2G
  B2C
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
  CREDITED
}

enum NRSStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
  NOT_REQUIRED
}

model InvoiceLine {
  id          String  @id @default(uuid())
  invoiceId   String
  productId   String?
  description String
  quantity    Decimal @db.Decimal(18, 3)
  unitPrice   Decimal @db.Decimal(18, 2)
  vatRate     Decimal @default(0.075) @db.Decimal(5, 4)
  vatAmount   Decimal @db.Decimal(18, 2)
  whtRate     Decimal @default(0) @db.Decimal(5, 4)
  whtAmount   Decimal @default(0) @db.Decimal(18, 2)
  lineTotal   Decimal @db.Decimal(18, 2)

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
}

model Payment {
  id         String        @id @default(uuid())
  tenantId   String
  invoiceId  String
  amount     Decimal       @db.Decimal(18, 2)
  currency   String        @default("NGN")
  method     String
  reference  String?       @unique
  status     PaymentStatus @default(PENDING)
  gateway    String?
  gatewayRef String?
  paidAt     DateTime?
  notes      String?
  createdAt  DateTime      @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model InvoiceReminder {
  id          String   @id @default(uuid())
  tenantId    String
  invoiceId   String
  channel     String   @default("EMAIL")
  recipient   String?
  status      String   @default("SENT")
  sentAt      DateTime?
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([invoiceId])
}

// ─────────────────────────────────────────────
// INVOICE MANAGEMENT FEATURES
// ─────────────────────────────────────────────

model InvoiceImport {
  id              String             @id @default(uuid())
  tenantId        String
  fileName        String
  fileSize        Int
  fileUrl         String
  importType      String             @default("CSV") // CSV, EXCEL, JSON
  status          String             @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  totalRecords    Int                @default(0)
  successCount    Int                @default(0)
  failureCount    Int                @default(0)
  errors          Json?              // Array of import errors
  duplicatesFound Int                @default(0)
  mappingConfig   Json?              // Column mapping config
  createdById     String?
  uploadedAt      DateTime           @default(now())
  processedAt     DateTime?
  createdAt       DateTime           @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
  @@index([createdAt])
}

model InvoiceOCRData {
  id              String   @id @default(uuid())
  tenantId        String
  invoiceId       String?
  fileName        String
  fileUrl         String
  fileType        String   // PDF, IMAGE, etc.
  ocrStatus       String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED, MANUAL_REVIEW
  extractedText   String?  @db.Text
  extractedData   Json?    // Parsed fields: amount, date, vendor, invoice number, etc.
  confidence      Float?   // OCR confidence score 0-100
  manualEdits     Json?    // Track manual corrections
  isValidated     Boolean  @default(false)
  validatedAt     DateTime?
  validatedBy     String?
  validationNotes String?
  processedAt     DateTime?
  createdById     String?
  createdAt       DateTime @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id])

  @@index([tenantId, ocrStatus])
  @@index([invoiceId])
}

model RecurringInvoice {
  id              String   @id @default(uuid())
  tenantId        String
  customerId      String
  templateName    String
  frequency       String   @default("MONTHLY") // MONTHLY, QUARTERLY, SEMI_ANNUAL, ANNUAL, CUSTOM
  dayOfMonth      Int      @default(1)
  startDate       DateTime
  endDate         DateTime?
  isActive        Boolean  @default(true)
  nextInvoiceDate DateTime
  lastInvoiceDate DateTime?
  invoiceCount    Int      @default(0)
  currency        String   @default("NGN")
  subtotal        Decimal  @db.Decimal(18, 2)
  vatRate         Decimal  @default(0.075) @db.Decimal(5, 4)
  description     String?
  lines           Json?    // Array of recurring invoice line items
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, isActive])
  @@index([nextInvoiceDate])
}

model InvoiceApprovalWorkflow {
  id              String   @id @default(uuid())
  tenantId        String
  invoiceId       String
  workflowStatus  String   @default("PENDING") // PENDING, IN_REVIEW, APPROVED, REJECTED, RECALL
  currentApprover String?  // User ID
  approverLevel   Int      @default(1)
  maxApprovalLevels Int    @default(2)
  approvalHistory Json?    // Array of approval records with timestamp, approver, status, notes
  rejectionReason String?
  approvedAt      DateTime?
  approvedBy      String?
  estimatedCompletionDate DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, workflowStatus])
  @@index([invoiceId])
  @@index([currentApprover])
}

model InvoiceDuplicateCheck {
  id                String   @id @default(uuid())
  tenantId          String
  invoiceId         String?
  supplierId        String?
  vendorInvoiceNo   String
  vendorName        String
  amount            Decimal  @db.Decimal(18, 2)
  currency          String   @default("NGN")
  invoiceDate       DateTime
  duplicateOf       String?  // ID of the original invoice if duplicate detected
  matchConfidence   Float?   // 0-100 score
  matchReason       String?  // Why it was flagged as duplicate
  isDuplicate       Boolean  @default(false)
  isApproved        Boolean  @default(false)
  approvedBy        String?
  approvedAt        DateTime?
  notes             String?
  checkStatus       String   @default("PENDING") // PENDING, VERIFIED, APPROVED, REJECTED
  createdAt         DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, isDuplicate])
  @@index([invoiceId])
  @@index([checkStatus])
}

model InvoiceNumbering {
  id              String   @id @default(uuid())
  tenantId        String   @unique
  currentNumber   Int      @default(1000)
  prefix          String   @default("INV")
  suffix          String?
  formatPattern   String   @default("{PREFIX}-{NUMBER}-{YEAR}") // Pattern for invoice numbering
  separator       String   @default("-")
  yearFormat      String   @default("YYYY") // YYYY or YY
  resetFrequency  String   @default("YEARLY") // YEARLY, MONTHLY, NONE
  lastResetDate   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

