# Server
NODE_ENV=development
# When behind Nginx: use 5133 and proxy /api to it. Do not use 80 (Nginx listens there).
PORT=5133

# One-shot local setup: from apps/api run `npm run env:init`
# - Replaces YOUR_POSTGRES_PASSWORD below with POSTGRES_PASSWORD (default: postgres)
# - Fills JWT_SECRET, JWT_REFRESH_SECRET, ENCRYPTION_KEY if still placeholders
# - Optional: POSTGRES_USER, POSTGRES_HOST, POSTGRES_PORT, POSTGRES_DB, POSTGRES_SHADOW_DB
# - Full URLs: INIT_DATABASE_URL=... INIT_SHADOW_DATABASE_URL=... npm run env:init -- --rewrite-db-urls

# Database (PostgreSQL; auth requires Tenant + User with bcrypt password hash)
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/cosmos_erp?schema=public
# Prisma migrate dev: empty shadow DB (create once: CREATE DATABASE cosmos_db_shadow OWNER your_app_user;)
SHADOW_DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/cosmos_db_shadow?schema=public

# Redis (optional)
REDIS_URL=redis://localhost:6379

# JWT (required for login — run `npm run env:init` to generate strong values)
JWT_SECRET=your_very_secure_long_random_string_here
JWT_REFRESH_SECRET=another_secure_long_random_string_for_refresh
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (32+ chars recommended; `npm run env:init` sets a 32-char key)
ENCRYPTION_KEY=your-32-char-encryption-key-here!!

# NRS/FIRS API (Nigerian Revenue Service)
NRS_API_URL=https://api.nrs.gov.ng/einvoicing/v1
NRS_API_KEY=your-nrs-api-key
NRS_SANDBOX_URL=https://sandbox.nrs.gov.ng/einvoicing/v1

# Paystack (checkout + Transfer API for marketplace seller payouts + webhook HMAC)
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public
# Webhook URL in Paystack dashboard: {API_URL}/api/webhooks/paystack — enable charge.success + transfer events

# SMS (logistics notifications — optional; configure one)
# TERMII_API_KEY=
# TERMII_SENDER_ID=CosmosERP
# TERMII_BASE_URL=https://api.ng.termii.com/api
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Flutterwave
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your-key
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your-key

# WhatsApp Business API
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token

# Set to true to skip tenant/marketplace registration welcome emails
# DISABLE_WELCOME_EMAILS=false

# SMTP — MySecureCloudHost / cPanel-style (SSL/TLS, port 465). OTP + all outbound mail.
# Passwords with $ or @: use single quotes in .env → SMTP_PASS='your$pass'
# If send fails with "certificate" / "self signed" / UNABLE_TO_VERIFY_LEAF_SIGNATURE:
# SMTP_TLS_REJECT_UNAUTHORIZED=false
SMTP_HOST=mail.cosmoserp.com.ng
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=you@cosmoserp.com.ng
SMTP_PASS=your-mailbox-password
MAIL_FROM=you@cosmoserp.com.ng
# Alternative (STARTTLS): SMTP_PORT=587, SMTP_SECURE=false
# Gmail: SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_USER=... SMTP_PASS=app-password

# GIG Logistics
GIG_API_URL=https://api.giglogistics.com/v1
GIG_API_KEY=your-gig-api-key

# Kobo360
KOBO360_API_URL=https://api.kobo360.com/v1
KOBO360_API_KEY=your-kobo360-api-key

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Platform Commission
MARKETPLACE_COMMISSION_RATE=0.05

# Super Admin (seeded)
SUPER_ADMIN_EMAIL=admin@rolandconsult.ng
SUPER_ADMIN_PASSWORD=ChangeMeImmediately!

# CORS (web frontends). After Let's Encrypt, use https://your-domain (no trailing path) — see docs/LETS-ENCRYPT.md
ERP_URL=http://localhost:3060
MARKETPLACE_URL=http://localhost:5174
ADMIN_URL=http://localhost:5175
# Production example (same origin as Nginx):
# API_PUBLIC_URL=https://cosmoserp.com.ng
# ERP_URL=https://cosmoserp.com.ng
# MARKETPLACE_URL=https://cosmoserp.com.ng
# ADMIN_URL=https://cosmoserp.com.ng
# Short-lived JWT for admin impersonation of tenant ERP users (e.g. 15m, 1h)
ADMIN_IMPERSONATION_EXPIRES_IN=15m
