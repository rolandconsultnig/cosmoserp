<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <ImageView
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="center"
        android:src="@drawable/cosmos_logo"
        app:tint="?attr/colorPrimary" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="Sale Successful!"
        android:textAppearance="?attr/textAppearanceHeadline6"
        android:textColor="#059669" />

    <TextView
        android:id="@+id/receiptNumberText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Receipt #POS-12345"
        android:textAppearance="?attr/textAppearanceBody2" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Digital Receipt / Invoice"
        android:textAppearance="?attr/textAppearanceSubtitle2"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEmailReceipt"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="Email"
            app:icon="@android:drawable/ic_dialog_email" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWhatsappReceipt"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:text="WhatsApp"
            app:icon="@android:drawable/stat_sys_phone_call" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPrintReceipt"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Print Receipt"
        app:icon="@android:drawable/ic_menu_agenda" />

    <Button
        android:id="@+id/btnNewSale"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="New Sale" />

</LinearLayout>
