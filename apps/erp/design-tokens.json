{
  "version": "1.0.0",
  "name": "Cosmos ERP Design System",
  "description": "Design tokens for Cosmos ERP mobile and web applications",
  "tokens": {
    "colors": {
      "primary": {
        "50": "#eff6ff",
        "100": "#dbeafe",
        "500": "#1a56db",
        "600": "#1d4ed8",
        "700": "#1e40af",
        "800": "#1e3a8a",
        "900": "#1e3066"
      },
      "nigeria": {
        "green": "#008751",
        "white": "#FFFFFF"
      },
      "semantic": {
        "success": "#10b981",
        "warning": "#f59e0b",
        "error": "#ef4444",
        "info": "#3b82f6"
      },
      "neutral": {
        "50": "#f8fafc",
        "100": "#f1f5f9",
        "200": "#e2e8f0",
        "300": "#cbd5e1",
        "400": "#94a3b8",
        "500": "#64748b",
        "600": "#475569",
        "700": "#334155",
        "800": "#1e293b",
        "900": "#0f172a"
      }
    },
    "spacing": {
      "xs": "4px",
      "sm": "8px",
      "md": "16px",
      "lg": "24px",
      "xl": "32px",
      "2xl": "48px",
      "3xl": "64px"
    },
    "typography": {
      "fontFamily": {
        "sans": ["Inter", "system-ui", "sans-serif"],
        "mono": ["JetBrains Mono", "monospace"]
      },
      "fontSize": {
        "xs": ["12px", "16px"],
        "sm": ["14px", "20px"],
        "base": ["16px", "24px"],
        "lg": ["18px", "28px"],
        "xl": ["20px", "28px"],
        "2xl": ["24px", "32px"],
        "3xl": ["30px", "36px"]
      },
      "fontWeight": {
        "normal": "400",
        "medium": "500",
        "semibold": "600",
        "bold": "700"
      }
    },
    "borderRadius": {
      "sm": "4px",
      "md": "8px",
      "lg": "12px",
      "xl": "16px",
      "full": "9999px"
    },
    "shadows": {
      "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
      "md": "0 4px 6px -1px rgba(0, 0, 0, 0.1)",
      "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1)",
      "xl": "0 20px 25px -5px rgba(0, 0, 0, 0.1)"
    },
    "breakpoints": {
      "mobile": "320px",
      "tablet": "768px",
      "desktop": "1024px",
      "wide": "1280px"
    }
  },
  "components": {
    "button": {
      "primary": {
        "backgroundColor": "primary.600",
        "color": "white",
        "borderRadius": "md",
        "paddingHorizontal": "lg",
        "paddingVertical": "sm",
        "fontWeight": "semibold",
        "fontSize": "sm",
        "hover": {
          "backgroundColor": "primary.700"
        },
        "disabled": {
          "backgroundColor": "neutral.300",
          "color": "neutral.500"
        }
      },
      "secondary": {
        "backgroundColor": "transparent",
        "color": "primary.600",
        "border": "1px solid",
        "borderColor": "primary.600",
        "borderRadius": "md",
        "paddingHorizontal": "lg",
        "paddingVertical": "sm",
        "fontWeight": "semibold",
        "fontSize": "sm",
        "hover": {
          "backgroundColor": "primary.50"
        }
      }
    },
    "card": {
      "backgroundColor": "white",
      "borderRadius": "lg",
      "padding": "lg",
      "shadow": "sm",
      "border": "1px solid",
      "borderColor": "neutral.200"
    },
    "input": {
      "backgroundColor": "white",
      "border": "1px solid",
      "borderColor": "neutral.300",
      "borderRadius": "md",
      "paddingHorizontal": "md",
      "paddingVertical": "sm",
      "fontSize": "sm",
      "focus": {
        "borderColor": "primary.500",
        "outline": "2px solid",
        "outlineColor": "primary.500",
        "outlineOffset": "2px"
      },
      "error": {
        "borderColor": "semantic.error"
      }
    },
    "sidebar": {
      "backgroundColor": "neutral.50",
      "width": "256px",
      "borderRight": "1px solid",
      "borderColor": "neutral.200"
    },
    "navigationItem": {
      "paddingHorizontal": "md",
      "paddingVertical": "sm",
      "borderRadius": "md",
      "color": "neutral.600",
      "fontSize": "sm",
      "fontWeight": "medium",
      "active": {
        "backgroundColor": "primary.50",
        "color": "primary.700"
      },
      "hover": {
        "backgroundColor": "primary.50",
        "color": "primary.700"
      }
    }
  },
  "figma": {
    "plugins": [
      "tailwindcss",
      "design-tokens",
      "content-reel",
      "arcade",
      "vectorizer"
    ],
    "styles": {
      "colors": {
        "Primary/50": {"value": "#eff6ff", "type": "color"},
        "Primary/600": {"value": "#1d4ed8", "type": "color"},
        "Nigeria/Green": {"value": "#008751", "type": "color"},
        "Success": {"value": "#10b981", "type": "color"},
        "Error": {"value": "#ef4444", "type": "color"}
      },
      "typography": {
        "Heading/1": {"value": {"fontFamily": "Inter", "fontWeight": 700, "fontSize": 30, "lineHeight": 36}, "type": "typography"},
        "Heading/2": {"value": {"fontFamily": "Inter", "fontWeight": 600, "fontSize": 24, "lineHeight": 32}, "type": "typography"},
        "Body/Regular": {"value": {"fontFamily": "Inter", "fontWeight": 400, "fontSize": 16, "lineHeight": 24}, "type": "typography"}
      },
      "effects": {
        "Shadow/Small": {"value": {"type": "dropShadow", "color": "#00000010", "offset": {"x": 0, "y": 1}, "radius": 2}, "type": "effect"},
        "Shadow/Medium": {"value": {"type": "dropShadow", "color": "#00000015", "offset": {"x": 0, "y": 4}, "radius": 6}, "type": "effect"}
      }
    },
    "components": {
      "Button/Primary": {
        "description": "Primary action button",
        "properties": {
          "State": {"type": "variant", "options": ["Default", "Hover", "Disabled"]},
          "Size": {"type": "variant", "options": ["Small", "Medium", "Large"]}
        }
      },
      "Card/Default": {
        "description": "Standard content card",
        "properties": {
          "Shadow": {"type": "variant", "options": ["None", "Small", "Medium"]}
        }
      }
    }
  }
}
